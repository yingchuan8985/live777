[Unit]
Description=A very simple, high performance, edge WebRTC SFU
Requires=network-online.target
After=network-online.target

[Service]
Type=simple
DynamicUser=yes
ExecStart=/usr/bin/live777 --config /etc/live777/live777.toml
WorkingDirectory=/var/lib/live777
StateDirectory=live777
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
